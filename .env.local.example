# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# After sign-in / sign-up, send users here first if new
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Convex — from `npx convex dev` or Convex dashboard
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex + Clerk JWT (Convex dashboard → Settings → Environment Variables)
# CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev
